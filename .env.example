# Pipeline Configuration
# Copia este archivo a .env y completa los valores

# OpenAI API (para evaluación de estándares - opcional)
OPENAI_API_KEY=sk-...

# Proveedor LLM (openai, anthropic, etc.)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# CKAN Portal Configuration
CKAN_BASE_URL=https://catalogodatos.nl.gob.mx
CKAN_API_KEY=  # Opcional para mayor rate limit

# Pipeline Settings
RATE_LIMIT_SECONDS=0.4
MAX_DATASETS=68

# Paths (relative to project root)
DATA_ROOT=./data
